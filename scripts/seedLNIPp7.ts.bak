// scripts/seedLNIPp7.ts

import postgres from 'postgres';
import { drizzle } from 'drizzle-orm/postgres-js';
import 'dotenv/config';
import * as schema from '../db/schema';

const queryClient = postgres(process.env.DATABASE_URL!);
const db = drizzle(queryClient, { schema });

const main = async () => {
	try {
		console.log('Seeding DB');
		await db.delete(schema.userProgress);
		await db.delete(schema.challengeProgress);
		await db.delete(schema.courses);
		await db.delete(schema.units);
		await db.delete(schema.lessons);
		await db.delete(schema.challenges);
		await db.delete(schema.challengeOptions);
		await db.delete(schema.classesHw);

		await db.delete(schema.userCourseProgress);
		await db.delete(schema.userDailyStats);
		await db.delete(schema.userSubscription);
		

		// ADD COURSES
		//
		const insertedCourse = await db.insert(schema.courses).values([
			{title:'ЛНИП Физика 7',imageSrc:'lnip_phy_7.svg'},
		]).returning({id: schema.courses.id});

		const courseId = insertedCourse[0]!.id;




        // 1. Вставляем units и получаем реальные ID
        const insertedUnits = await db.insert(schema.units).values([
        {courseId:courseId,title:'Средняя скорость',description:'Описание 1',order:101,imageSrc:'LottieUnit1',},
        {courseId:courseId,title:'Масса',description:'Описание 2',order:102,imageSrc:'LottieUnit2',},
        {courseId:courseId,title:'Средняя плотность',description:'Описание 3',order:103,imageSrc:'LottieUnit3',},
        {courseId:courseId,title:'Давление',description:'Описание 4',order:104,imageSrc:'LottieUnit4',},
        {courseId:courseId,title:'Архимед',description:'Описание 5',order:105,imageSrc:'LottieUnit5',},
        {courseId:courseId,title:'Цилиндрический сосуд',description:'Описание 6',order:106,imageSrc:'LottieUnit6',},
        {courseId:courseId,title:'U-трубка',description:'Описание 7',order:107,imageSrc:'LottieUnit7',},
        {courseId:courseId,title:'Джоули и Ватты',description:'Описание 8',order:108,imageSrc:'LottieUnit8',},
        {courseId:courseId,title:'Механизмы',description:'Описание 9',order:109,imageSrc:'LottieUnit9',},
        ]).returning({id: schema.units.id});

        // Создаем маппинг: старые unitIds -> новые ID
        const unitMap = new Map([
        [101, insertedUnits[0]!.id],
        [102, insertedUnits[1]!.id],
        [103, insertedUnits[2]!.id],
        [104, insertedUnits[3]!.id],
        [105, insertedUnits[4]!.id],
        [106, insertedUnits[5]!.id],
        [107, insertedUnits[6]!.id],
        [108, insertedUnits[7]!.id],
        [109, insertedUnits[8]!.id],
        ]);

        // 2. Вставляем lessons с реальными unitIds и получаем их ID
        const insertedLessons = await db.insert(schema.lessons).values([
        {unitId:unitMap.get(101),title:'Средняя скорость 1',order:101,},
        {unitId:unitMap.get(101),title:'Средняя скорость 2',order:102,},
        {unitId:unitMap.get(101),title:'Средняя скорость 3',order:103,},
        {unitId:unitMap.get(101),title:'Средняя скорость 4',order:104,},
        {unitId:unitMap.get(101),title:'Средняя скорость Обгон',order:105,},
        {unitId:unitMap.get(101),title:'Поезд Скорость',order:106,},
        {unitId:unitMap.get(102),title:'Масса 1',order:107,},
        {unitId:unitMap.get(102),title:'Масса 2',order:108,},
        {unitId:unitMap.get(103),title:'Средняя Плотность 1',order:109,},
        {unitId:unitMap.get(103),title:'Средняя Плотность 2 Часть',order:110,},
        {unitId:unitMap.get(103),title:'Средняя Плотность 3',order:111,},
        {unitId:unitMap.get(104),title:'Давление 1',order:112,},
        {unitId:unitMap.get(104),title:'Давление 2',order:113,},
        {unitId:unitMap.get(104),title:'Давление 3 Аквариум',order:114,},
        {unitId:unitMap.get(104),title:'Корабль',order:115,},
        {unitId:unitMap.get(105),title:'Архимед 1',order:116,},
        {unitId:unitMap.get(105),title:'Архимед 2',order:117,},
        {unitId:unitMap.get(105),title:'Архимед 3 Мощность',order:118,},
        {unitId:unitMap.get(105),title:'Архимед 4 Полость',order:119,},
        {unitId:unitMap.get(105),title:'Льдина',order:120,},
        {unitId:unitMap.get(106),title:'Цилиндрический сосуд',order:121,},
        {unitId:unitMap.get(107),title:'U-трубка 1',order:122,},
        {unitId:unitMap.get(107),title:'U-трубка 2',order:123,},
        {unitId:unitMap.get(107),title:'U-трубка 3',order:124,},
        {unitId:unitMap.get(108),title:'Мощность',order:125,},
        {unitId:unitMap.get(108),title:'Работа',order:126,},
        {unitId:unitMap.get(109),title:'Импульс',order:127,},
        {unitId:unitMap.get(109),title:'Рычаг Пресс КПД',order:128,},
        ]).returning({id: schema.lessons.id});

        // Создаем маппинг: старые lessonIds -> новые ID
        const lessonMap = new Map([
        [101, insertedLessons[0]!.id],
        [102, insertedLessons[1]!.id],
        [103, insertedLessons[2]!.id],
        [104, insertedLessons[3]!.id],
        [105, insertedLessons[4]!.id],
        [106, insertedLessons[5]!.id],
        [107, insertedLessons[6]!.id],
        [108, insertedLessons[7]!.id],
        [109, insertedLessons[8]!.id],
        [110, insertedLessons[9]!.id],
        [111, insertedLessons[10]!.id],
        [112, insertedLessons[11]!.id],
        [113, insertedLessons[12]!.id],
        [114, insertedLessons[13]!.id],
        [115, insertedLessons[14]!.id],
        [116, insertedLessons[15]!.id],
        [117, insertedLessons[16]!.id],
        [118, insertedLessons[17]!.id],
        [119, insertedLessons[18]!.id],
        [120, insertedLessons[19]!.id],
        [121, insertedLessons[20]!.id],
        [122, insertedLessons[21]!.id],
        [123, insertedLessons[22]!.id],
        [124, insertedLessons[23]!.id],
        [125, insertedLessons[24]!.id],
        [126, insertedLessons[25]!.id],
        [127, insertedLessons[26]!.id],
        [128, insertedLessons[27]!.id],
        ]);




// 3. Вставляем challenges с реальными lessonIds и получаем их ID
const insertedChallenges = await db.insert(schema.challenges).values([{lessonId:lessonMap.get(101),type:'ASSIST',order:101101001,question:'На горизонтальном участке пути автомобиль ехал со скоростью 72 км/ч в течение 10 мин, а подъем проехал со скоростью 36 км/ч за 20 мин. Чему равна средняя скорость на всем пути?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:''},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101002,question:'Пассажир такси по часам и спидометру определил, что 5 мин автомобиль двигался со скоростью 40 км/ч, 2 мин со скоростью 30 км/ч и 3 мин со скоростью 20 км/ч. Определите среднюю скорость автомобиля за все время движения.',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101003,question:'Автомобиль проехал 72 км со скоростью 10 м/с, а затем 20 мин ехал со скоростью 54 км/ч. Какова средняя скорость движения на всем пути?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101004,question:'Пешеход шел 20 мин со скоростью 6 км/час, а затем прошёл еще 2,7 км со скоростью 1,5 м/с. Какова средняя скорость пешехода на всем пути?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101005,question:'Велосипедист проехал 18 км со скоростью 10 м/с, а затем 15 мин ехал со скоростью 54 км/ч. Какова средняя скорость велосипедиста на всем пути?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101006,question:'Первые 1500 м автобус двигался со скоростью 25 м/с, затем в течение 40 с он двигался со скоростью 20 м/с, после остановки, длившейся в течение 70 с, автобус последние 900 м прошёл за время 30 с. Найти среднюю скорость автобуса на всем пути.',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101007,question:'Пароход прошёл 1000 км за 2 суток. Затем 0,5 суток он заправлялся в порту и продолжил свой путь, пройдя 3000 км со скоростью 30 км/ч. Какова средняя скорость парохода на всем пути?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101008,question:'За первые два часа автомобиль проехал 60 км, затем два часа ехал со скоростью 40 км/час, а последние 72 км ехал со скоростью 10 м/с. Какова средняя скорость автомобиля на всем пути?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101009,question:'В течение 40 с поезд двигался равномерно со скоростью 81 км/ч. Какой путь прошёл поезд за это время?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101010,question:'За 5 ч 30 мин велосипедист проделал путь 99 км. С какой скоростью двигался велосипедист?',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(101),type:'ASSIST',order:101101011,question:'Автомобиль проехал первые 4 км со скоростью 20 км/ч, а следующие 12 км со скоростью 40 км/ч. Найти среднюю скорость автомобиля на всем пути.',points:10,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102001,question:'Теплоход плывет из Самары до Волгограда со скоростью 25 км/ч и обратно со скоростью 15 км/ч. Найти среднюю скорость теплохода за все время движения.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102002,question:'Половину пути лыжник прошёл со скоростью 10 м/с, следующую четверть пути со скоростью 15 м/с, а оставшуюся часть пути со скоростью 10 м/с. Какова средняя скорость лыжника на всем пути?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102003,question:'Треть пути велосипедист ехал со скоростью 72 км/ч, а оставшийся путь со скоростью 15 м/с. Какова средняя скорость на всем пути?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102004,question:'Расстояние между двумя городами равно 60 км. Первую половину этого пути велосипедист ехал со скоростью 30 км/ч, а вторую половину со скоростью 20 км/ч. Чему равна средняя скорость его движения на всем пути?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102005,question:'Лыжник прошёл 20% дистанции со скоростью 10 м/с, а остальную часть дистанции со скоростью 54 км/ч. Какова средняя скорость лыжника на всей дистанции?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102006,question:'Четвертую часть пути велосипедист проехал со скоростью 36 км/ч, а оставшийся путь со скоростью 20 м/с. Какова средняя скорость велосипедиста на всем пути?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102007,question:'Две трети пути автомобиль двигался со скоростью 72 км/ч, а оставшийся путь со скоростью в полтора раза меньшей. Какова средняя скорость автомобиля на всем пути?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102008,question:'Треть пути машина ехала со скоростью 15 м/с. На оставшийся путь она затратила такое же время, как и на первую треть пути. Найти среднюю скорость машины на всем пути.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102009,question:'Найти среднюю скорость автомобиля, если первую треть пути он двигался со скоростью 10 м/с, вторую треть пути двигался со скоростью 12 м/с, а последнюю треть пути со скоростью 15 м/с.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102010,question:'Найти среднюю скорость автомобиля, если первую треть времени он двигался со скоростью 14 м/с, вторую треть времени двигался со скоростью 16 м/с, а третью треть времени со скоростью 9 м/с.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102011,question:'Велосипедист проехал первую половину пути со скоростью V = 12 км/ч, а вторую половину пути с какой-то другой скоростью. Как велика эта скорость, если известно, что средняя скорость его движения на всем пути 8 км/ч.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102012,question:'Три четверти своего пути автомобиль прошёл со скоростью 60 км/ч, остальную часть пути со скоростью 80 км/ч. Какова средняя скорость автомобиля на всем пути?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102013,question:'Мотоциклист проехал 40% пути со скоростью 72 км/ч, а оставшийся путь со скоростью 54 км/ч. Определите среднюю скорость мотоциклиста на всем пути.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102014,question:'Средняя скорость автобуса на маршруте должна составлять 40 км/ч. Однако 60% маршрута он прошёл со скоростью 30 км/ч. С какой скоростью необходимо ему пройти оставшуюся часть пути, чтобы прибыть на конечный пункт вовремя?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102015,question:'Две трети дистанции бегун бежал со скоростью 3 м/с, а оставшуюся часть дистанции со скоростью в 1,5 раза меньшей. Какова средняя скорость бегуна на дистанции?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102016,question:'Самолет 40% пути летел со скоростью 800 км/ч, а на оставшийся путь затратил такое же время, как и на первую часть пути. Найти среднюю скорость самолета на всем пути.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102017,question:'Из города в аэропорт одновременно выехали две машины. Первая машина весь путь до аэропорта проехала со скоростью 20 м/с. Вторая машина 20 % пути проехала со скоростью 12 м/с. С какой скоростью проехала оставшийся путь вторая машина, если она приехала в аэропорт одновременно с первой?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102018,question:'Троллейбус должен проходить маршрут со средней скоростью 35 км/ч. Однако 40 % маршрута он ехал со скоростью 28 км/ч. С какой скоростью необходимо ему пройти оставшийся путь, чтобы прибыть на конечный пункт вовремя?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(102),type:'ASSIST',order:101102019,question:'Путешественник преодолел 300 км за 15 ч. Первую половину пули он ехал на автомобиле, в вторую - на слоне. С какой скоростью он ехал на слоне, если скорость автомобиля в 4 раза больше скорости слона?',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103001,question:'Первую половину пути автобус шел со скоростью в 8 раз большей, чем вторую. Средняя скорость автобуса на всем пути равна 16 км/час. Определить скорость автобуса на второй половине пути.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103002,question:'Поезд первую половину пути шел со скоростью в 1,5 раза больше, чем вторую половину пути. Какова скорость поезда на каждом участке, если средняя скорость прохождения всего пути равна 12 м/с.?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103003,question:'Найти среднюю скорость автомобиля, если известно, что четверть всего времени он двигался со скоростью 16 м/с, а все остальное время со скорость 8 м/с.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103004,question:'Модель гоночного автомобиля имеет две скорости 1 м/с и 2 м/с. Сколько секунд должен ехать автомобиль на первой скорости и сколько на второй, чтобы проехать 20 метров за 12 секунд?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103005,question:'Из города в деревню выехали одновременно две машины. Первая весь путь проехала со скоростью 60 км/ч. Вторая 40% пути проехала со скоростью 40 км/ч. С какой скоростью проехала оставшийся путь вторая машина, если она приехала в деревню одновременно с первой?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103006,question:'Почтальон повез почту на велосипеде со скоростью 18 км/ч. До почтамта 27 км. Через час вдогонку выехала машина. С какой минимальной скоростью нужно ей ехать, чтобы перехватить почту?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103007,question:'Два мальчика поехали на велосипедах на озеро, один со скоростью 20 км/ч, другой со скоростью 5 м/с. Найти расстояние до озера, если первый приехал на 2 минуты раньше второго.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103008,question:'По бикфордову шнуру пламя распространяется равномерно со скоростью 0,8 см/с. Какой длины шнур необходимо ваять, чтобы поджигающий его мог отбежать на 120 м, пока пламя дойдет до взрывчатого вещества? Скорость бега принять равной 4 м/с.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103009,question:'Грузовик повез зерно на элеватор со скоростью 40 км/ч. Обратно он ехал со скоростью 60 км/ч. Каково расстояние до элеватора, если на обратный путь грузовик затратил времени на 24 мин меньше?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103010,question:'Из города выехал велосипедист. Через 40 мин вслед за ним выехал мотоциклист, скорость которого в два раза больше, чем у велосипедиста. Сколько времени потребуется мотоциклисту, чтобы догнать велосипедиста?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103011,question:'Скорость первого конькобежца на 2 км/ч больше, чем второго. Через сколько минут после старта первый конькобежец будет опережать второго на 50 м?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103012,question:'Между двумя пристанями на реке ходит катер: вниз по реке со скоростью 20 км/ч, вверх - со скоростью 16 км/ч. Каково расстояние между пристанями, если поездка вверх по реке занимает на 12 мин больше времени, чем вниз?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103013,question:'Из порта вышел теплоход. Через полчаса вдогонку за ним вышел пограничный катер, скорость которого в 3 раза больше скорости теплохода. Сколько времени потребуется катеру, чтобы догнать теплоход?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103014,question:'Через 10 с после старта первая машина обогнала вторую на 100 м. Какова скорость первой машины, если скорость второй 200 км/ч?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(103),type:'ASSIST',order:101103015,question:'Из города вышел турист, а через 3 часа вслед за ним выехал велосипедист. Скорость велосипедиста 30 км/ч, туриста - 6 км/ч. Через какое время после выезда велосипедиста расстояние между велосипедистом и туристом будет равно 10 км?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(104),type:'ASSIST',order:101104001,question:'Расстояние от деревни до города машина проехала со скоростью 40 км/ч. На обратный путь она затратила в 1,5 раза меньшее время. Какова средняя скорость машины на всем пути до города и обратно?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(104),type:'ASSIST',order:101104002,question:'Средняя скорость поезда на всем пути 12 м/с, причём 40% всего пути он шел со скоростью v1, а оставшуюся часть шел со скоростью v2, в два раза большей, чем первую часть. Каковы скорости v1 и v2?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(104),type:'ASSIST',order:101104003,question:'Найти среднюю скорость тела в двух случаях: а) первую четверть времени оно двигалось со скоростью 7 м/с, оставшееся время со скоростью 4 м/с. b) первую четверть пути оно двигалось со скоростью 7 м/с, оставшийся путь со скоростью 4 м/с.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(104),type:'ASSIST',order:101104004,question:'Найти среднюю скорость движения автомобиля, если половину всего времени он двигался со скоростью 72 км/ч, четверть времени со скоростью 15 м/с, а оставшееся время со скоростью 36 км/ч.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(104),type:'ASSIST',order:101104005,question:'Три четверти пути машина ехала со скоростью 15 м/с. На оставшийся путь она затратила в два раза меньше времени, чем на первую часть пути. Найти среднюю скорость машины за все время движения.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(104),type:'ASSIST',order:101104006,question:'Первую половину пути лыжник прошёл со скоростью в 2 раза большей, чем вторую. Какова скорость лыжника на каждом участке, если средняя скорость прохождения всего пути равна 8 км/ч?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(104),type:'ASSIST',order:101104007,question:'Путешественник сначала ехал на лошади со скоростью 30 км/ч, а потом на осле со скоростью 6 км/ч. Какую часть пути он ехал на лошади, если средняя скорость его движения на всем пути оказалась равной 12 км/ч?',points:60,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(105),type:'ASSIST',order:101105001,question:'Пух пошел в гости к Кролику. Через 10 мин к его домику подошел Пятачок и, увидев, что Пуха нет дома, побежал за ним вдогонку. Через сколько минут он догонит друга, если скорость его движения в 2 раза больше?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(105),type:'ASSIST',order:101105002,question:'На соревнованиях в лесу Заяц и Лиса участвовали в забеге. Оказалось, что скорость Лисы составляет 90 % от скорости Зайца, поэтому, когда Заяц финишировал, Лисе до финиша оставалось 100 м. Какова длина дистанции?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(105),type:'ASSIST',order:101105003,question:'Лыжник стартовал со скоростью 18 км/час. Через 30 с стартовал следующий лыжник, который догнал первого через 30 мин. Какова скорость второго лыжника?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(105),type:'ASSIST',order:101105004,question:'Первая яхта идет со скоростью 20 км/ч и проходит дистанцию на 30 мин быстрее, чем вторая. Какова длина дистанции, если скорость второй яхты 18 км/ч?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(106),type:'ASSIST',order:101106001,question:'Через полустанок проследовал товарный поезд со скоростью 10 м/с. Спустя 0,5 часа, через этот же полустанок в том же направлении проследовал экспресс со скоростью 54 км/ч. Через какое время, после того как прошёл товарный поезд, и на каком расстоянии от полустанка экспресс нагонит товарный поезд?',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107001,question:'Металлическая пластинка площадью 12,5 см² покрывается тонким слоем золота (ρ =20 г/см³), отчего ее вес увеличивается на 0,00057. Какова толщина покрытия? Принять g = 10 Н/кг.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107002,question:'Плотность березовых дров 700 кг/м³. Сколько кубометров березовых дров можно погрузить в автомашину грузоподьемностью 25 кН? g = 10 Н/кг.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107003,question:'На какое расстояние можно протянуть медный провод сечением 10 мм², если этого провода имеется 178 кг. Плотность меди 8900 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107004,question:'В магазинах провода нередко продают на вес. Сколько килограммов медного провода сечением 1 мм² нужно купить, если покупателю требуется 200 м провода? Плотность меди 8900 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107005,question:'Крыша дома, площадь поверхности которой равна 1000 м², покрыта слоем снега толщиной 10 см. Плотность снега 200 кг/м³. Сколько тонн снега скопилось на крыше?',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107006,question:'Золото можно расплющить до толщины 0,0001 см. Поверхность какой площади можно покрыть листом золота массой 2 г. Плотность золота 20 г/см³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107007,question:'Моток медной проволоки с площадью поперечного сечения 2 ммм²? имеет массу 17,8 кг. Как, не разматывая моток, определить длину проволоки? Чему она равна? Плотность меди 8900 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107008,question:'Бетонная плита имеет длину 4 м, ширину 1,5 м н толщину 25 см. Плотность бетона 2200 кг/м³. Определите массу плиты.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107009,question:'Какая масса золота пойдет на золочение куполов храма, площадь которых 10 м², если толщина покрытия 0,005 мм? Плотность золота принять равной 20000 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107010,question:'Моток медного провода с площадью поперечного сечения 2 мм² имеет массу 1,78 кг. Какова длина провода? Плотность меди 8900 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107011,question:'На серебрение ложек пошло 10 г серебра. Толщина слоя серебра 0,005 мм. Какова общая площадь поверхности ложек? Принять Плотность серебра = 10000 кг/м³?',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107012,question:'Рассчитайте, что покажет динамометр, если на него подвесить железную гирю, объемом 128,2 см³. Плотность железа 7800 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107013,question:'Сколько штук строительного кирпича размером 250x120x65 мм допускается перевозить на машине грузоподьемностью 4 т? Плотность кирпича 1600 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(107),type:'ASSIST',order:102107014,question:'Какая масса золота пойдет на золочение куполов церкви общей площадью 5 м², при толщине покрытия 0,0025 мм? Плотность золота 19600 кг/м³.',points:25,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108001,question:'Деревянная модель отливки имеет массу 4 кг. Какова будет масса латунной отливки, если плотность дерева ρ1 = 500 кг/м³, латуни ρ2 = 8500 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108002,question:'При одинаковых объемах масса куска железа на 12,5 кг больше, чем масса куска алюминия. Определить массы куска железа и куска алюминия. Плотность железа ρ =7700 кг/м³, плотность алюминия ρ2 = 2700 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108003,question:'Какой объем воды образуется при таянии ледяного куба с длиной ребра 3 м? Плотность льда 900 кг/м³, воды 1000 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108004,question:'Каков объем емкостей танкера, если он вмещает 32000 т нефти? Плотность нефти 800 кг/м³?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108005,question:'Какая масса керосина войдет в бак длиной 1,2 м, шириной 0,7 м и высотой 50 см? Плотность керосина 800 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108006,question:'Отливки из свинца и олова имеют одинаковый объем, при этом масса. свинцовой отливки на 4 кг больше. Определить массу каждой отливки. Плотность свинца 11300 кг/м³, олова 7300 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108007,question:'В аквариум длиной 30 см и шириной 20 см налита вода до высоты 25 см. Определите массу воды в аквариуме. Плотность воды 1000 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108008,question:'Для промывки медной детали массой 17,8 кг ее опустили в бак с керосином. Определите массу керосина, вытесненного этой деталью. Плотность меди 8,9 г/см³, керосина - 0,8 г/см³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108009,question:'При одинаковых массах объем шара из алюминия на 6,2 дм³ больше, чем объем шара из меди. Какова масса шаров? Плотность алюминия 2700 кг/м³, меди - 8900 кг/м³?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108010,question:'С какой скоростью должна двигаться нефть в трубопроводе с площадью поперечного сечения 100 см², чтобы в течение часа протекло 18 м³ нефти?',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108011,question:'Какую массу масла вытесняет стальная деталь массой 156 г при полном ее погружения в масло? Плотность стали 7800 кг/м³, масла 900 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108012,question:'Определите массу оконного стекла длиной 2 м, высотой 2,5 м и толщиной 0,6 см. Плотность стекла 2500 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(108),type:'ASSIST',order:102108013,question:'При одинаковых массах объем шара из алюминия на 5,8 дм³ больше, чем Объем шара из латуни. Какова масса шаров? Плотность алюминия 2700 кг/м³, латуни - 8500 кг/м³.',points:30,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109001,question:'Эталон килограмма массы изготовлен из сплава, состоящего на 90% из платины (ρ1 = 21500 кг/м³) и на 10% из иридия (ρ2 = 22400 кг/м³). Определить плотность сплава и объем эталона, считая объем сплава равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109002,question:'Сплав состоит из золота (ρ1 = 20000 кг/м³) и серебра (ρ2 = 10000 кг/м³), причём массы золота и серебра в сплаве равны. Какова плотность сплава? Считать объем сплава равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109003,question:'Золото (ρ1 = 20000 кг/м³) составляет 40% массы сплава, а серебро (ρ2 = 10000 кг/м³) оставшуюся часть. Найти плотность сплава. Считать объем сплава равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109004,question:'В сплаве золота с серебром золото составляет 60% массы сплава. Какова плотность сплава? Плотность золота 20 г/см³, серебра 10 г/см³. Считать объем сплава равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109005,question:'Сколько литров бензина и масла нужно взять, чтобы получить 40 литров смеси с плотностью 750 кг/м³? Плотность бензина 700 кг/м³ масла 900 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109006,question:'К 20 литрам воды добавили 8 литров спирта. Какова плотность полученной смеси? Плотность спирта 800 кг/м³, воды 1000 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109007,question:'Сплав состоит из олова массой 2,92 кг и свинца массой 1,13 кг. Какова плотность сплава, если считать, что объем сплава равен сумме объемов его составных частей? Плотность олова 7300 кг/м³, свинца 11300 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109008,question:'Кусок сплава из свинца и олова массой 664 г имеет плотность 8,3 г/см³. Определите массу свинца в сплаве. Принять объем сплава равным сумме объемов его составных частей. Плотность олова 7,3 г/см³, свинца 11,3 г/см³',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109009,question:'K 15 литрам бензина добавили масло. Плотность полученной смеси оказалась равной 750 кг/м³. Сколько литров масла добавили? Плотность бензина 700 кг/м³, масла 900 кг/м³. Считать объем смеси равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109010,question:'В воду добавили кислоту, объем которой в два раза меньше объема воды. Плотность раствора оказалась равной 1,3 г/см³. Какова плотность кислоты? Плотность воды 1 г/см³. Объем смеси считать равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109011,question:'Когда сплавили 4 г серебра с некоторым количеством золота, то получили сплав с плотностью 16 г/см³. Сколько грамм золота в сплаве? Плотность золота 20 г/см³. Серебра 10 г/см³. Объем сплава считать равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109012,question:'Сколько литров воды и спирта необходимо смешать, чтобы получить 40 литров смеси с плотностью 920 кг/м³? Считать объем смеси равным сумме объемов составных частей. Плотность воды 1000 кг/м³, спирта 800 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109013,question:'Сплав состоит из свинца и олова, объемы которых равны. Какова плотность сплава? Считать объем сплава равным сумме объемов составных частей. Плотность свинца 11300 кг/м³, олова 7300 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109014,question:'Когда смешали одинаковые массы воды и кислоты, то оказалось, что плотность раствора 1,2 г/см³. Какова плотность кислоты? Плотность воды 1 г/см³. Объем смеси считать равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109015,question:'Сплав золота и серебра массой 128 г имеет плотность 16 г/см³. Определите массу золота в сплаве, считая объем сплава равным сумме объемов составных частей. Принять плотность золота равной 20000 кг/м³, серебра - 10000 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109016,question:'Когда сплавили 16 г серебра с некоторым количеством золота, то получили сплав с плотностью 16 г/см³. Сколько грамм золота в сплаве? Принять плотность золота равной 20000 кг/м³, серебра - 10000 кг/м³. Объем сплава считать равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109017,question:'Сколько литров воды и спирта необходимо смешать, чтобы получить 100 л смеси с плотностью 920 кг/м³? Считать объем смеси равным сумме объемов составных частей. Плотность воды 1000 кг/м³, Плотность спирта 800 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109018,question:'Когда смешали 80 л спирта с водой, то получили смесь с плотностью 0,92 г/см³. Сколько литров воды в смеси? Считать объем смеси равным сумме объемов составных частей. Плотность воды 1000 кг/м³, спирта - 800 кг/м³',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109019,question:'К 30 литрам воды добавили спирт. Плотность смеси оказалась равной 920 кг/м³. Сколько литров спирта добавили? Считать объем смеси равным сумме объемов составных частей. Плотность спирта 800 кг/м³, воды 1000 кг/м³.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109020,question:'В воду добавили кислоту, объем которой в три раза меньше объема воды. Плотность раствора оказалась равной 1,2 г/см³. Какова плотность кислоты? Плотность воды 1 г/см³. Объем смеси считать равным сумме объемов составных частей.',points:20,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109021,question:'Сплав состоит из 14 г золота и 6,45 г платины. Определить плотность сплава. Плотность золота 20000 кг/м³, плотность платины 21500 кг/м³ Объем сплава считать равным сумме объемов составных частей.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(109),type:'ASSIST',order:103109022,question:'Сплав состоит из 40 г золота, 4,3 г платины и 8 г серебра. Какова плотность сплава? Плотность золота 20000 кг/м³, плотность платины 21500 кг/м³, плотность серебра 10000 кг/м³.',points:15,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(110),type:'ASSIST',order:103110001,question:'В чистой воде растворена кислота. Плотность раствора 1,2 г/см³. Определить, какую часть массы всего раствора составляет кислота, если плотность кислоты 1,8 г/см³, воды 1 г/см³. Принять объем раствора равным сумме объемов составных частей.',points:50,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
{lessonId:lessonMap.get(110),type:'ASSIST',order:103110002,question:'Какую часть всего объема в смеси воды со спиртом занимает спирт, если плотность смеси 920 кг/м³. Плотность спирта 800 кг/м³, плотность воды 1000 кг/м³? Принять объем смеси равным сумме объемов составных частей.',points:50,author:'ЛНИП Физ 7',imageSrc:'',difficulty:'',},
